[app]
title = Matus
package.name = matus
package.domain = org.matus
source.dir = .
source.include_exts = py,png,jpg,kv,atlas,matus
version = 0.1
requirements = python3,kivy
orientation = portrait
fullscreen = 0
android.permissions = INTERNET
android.api = 31
android.minapi = 21
android.sdk = 31
android.ndk = 23b
android.archs = arm64-v8a, armeabi-v7a
osx.python_version = 3
osx.kivy_version = 1.9.1
[buildozer]
log_level = 2
warn_on_root = 1
